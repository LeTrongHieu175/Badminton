PORT=4000
NODE_ENV=production

AUTO_APPLY_SCHEMA=true
AUTO_RUN_SEED=true

APP_ORIGIN=https://${{web.RAILWAY_PUBLIC_DOMAIN}}
SOCKET_CORS_ORIGIN=https://${{web.RAILWAY_PUBLIC_DOMAIN}}

DATABASE_URL=${{postgres.DATABASE_URL}}
PG_POOL_MAX=20

REDIS_URL=${{redis.REDIS_URL}}
REDIS_ENABLED=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

BOOKING_LOCK_TTL_SECONDS=600
BOOKING_SWEEP_INTERVAL_MS=30000
BOOKING_EXPIRY_JOB_ENABLED=true

PAYMENT_PROVIDER=sepay
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
DEFAULT_CURRENCY=VND
SEPAY_API_KEY=spay_change_me
SEPAY_IPN_SECRET=spsk_change_me
SEPAY_MERCHANT_CODE=SP-LIVE-LT284A2A
SEPAY_BANK_CODE=MB
SEPAY_TRANSFER_PREFIX=BOOKING
BANK_NAME=MB Bank
BANK_ACCOUNT_NO=55463688
BANK_ACCOUNT_NAME=LE TRONG HIEU

AI_SERVICE_BASE_URL=http://${{ai.RAILWAY_PRIVATE_DOMAIN}}:${{ai.PORT}}
