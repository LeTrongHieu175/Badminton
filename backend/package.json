{
  "name": "smart-badminton-backend",
  "version": "1.0.0",
  "description": "Smart Badminton Court Management System backend service",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "psql \"$DATABASE_URL\" -f src/db/schema.sql",
    "seed": "psql \"$DATABASE_URL\" -f src/db/seed.sql",
    "test": "jest --runInBand"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "redis": "^4.6.15",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.1"
  }
}
